# Copy this file to ".env" and edit the values you want to override.
# Anything left commented out falls back to the default in config.py.

# ---- Languages ----
# SOURCE_LANG=fr
# TARGET_LANG=en

# ---- Groq API (free key, no credit card: https://console.groq.com/keys) ----
# One key powers BOTH cloud transcription (Whisper) and LLM translation.
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ---- Translation engine ----
# auto (LLM if GROQ_API_KEY set, else Google) | llm | google
# TRANSLATION_ENGINE=auto
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Phrase cache (exact full-sentence TM across sessions) — latency A/B tests:
# PHRASE_CACHE=false          # true = lookup before LLM/Google; [pc on/off] at runtime
# PHRASE_CACHE_SIZE=10000     # in-memory LRU cap
# PHRASE_CACHE_WARMUP=true    # load pairs from SQLite/chunks on start
# PHRASE_CACHE_LOG=true       # log HIT/MISS on Sistema panel
# PHRASE_CACHE_LC_ALSO_REVERSE=true  # LC EN→PT also stores PT→EN (same texts swapped)
# Runtime: pc | pc on|off | pc force | pc last | pc good|bad | pc undo | pc backup | pc restore

# ---- Speech-to-text engine ----
# STT_ENGINE: auto (Groq if a key is set, else local) | groq | local
# Groq runs whisper-large-v3 — much more accurate than the small local model,
# free, fast, and offloads your CPU. Needs GROQ_API_KEY (same key as below) + net.
# STT_ENGINE=auto
# GROQ_STT_MODEL=whisper-large-v3      # or whisper-large-v3-turbo (faster)
# GROQ_STT_TIMEOUT=20.0
# Bias recognition toward your vocabulary / names / accents (both engines).
# Write the prompt in the SAME language as SOURCE_LANG (or leave empty).
# Wrong language here → Whisper transcribes in the wrong language ("portunhol").
# STT_INITIAL_PROMPT=Réunion sur LiveLingo, VB-Cable, Whisper, Groq, Teams.
# STT_HALLUCINATION_FILTER=true   # drop "Legenda por …" etc. on silent tails

# ---- Local Whisper (used when STT_ENGINE=local, or as a fallback) ----
# WHISPER_MODEL=small          # tiny | base | small | medium | large-v3 | large-v3-turbo
# WHISPER_DEVICE=cpu           # cpu | cuda
# WHISPER_COMPUTE_TYPE=int8    # int8 (cpu) | float16 (gpu)
# WHISPER_BEAM_SIZE=5
# WHISPER_VAD_FILTER=true
#
# ---- Provider failover / HA (runtime; app stays up) ----
# STT_FALLBACK=local           # local | none — Groq fail → faster-whisper
# TRANSLATION_FALLBACK=google  # google | none — LLM fail → Google Translate
# FAILOVER_MAX_RETRIES=1       # extra primary tries on timeout/429/5xx only
# FAILOVER_RETRY_SLEEP_S=0.35
# CIRCUIT_FAIL_THRESHOLD=3     # open circuit after N primary failures
# CIRCUIT_COOLDOWN_S=60        # seconds before probing primary again
# STT_FALLBACK_WAIT_S=8        # max wait for local Whisper warm-up on fallback
# STT_WARMUP_LOCAL=true        # load Whisper in background when Groq is primary
# FAILOVER_LOG=true            # System panel messages (rate-limited)

# ---- Text-to-speech ----
# TTS_ENGINE=edge            # edge | piper | hybrid (edge 1st chunk + piper tail)
# TTS_HYBRID=true            # with piper: edge for first live chunk (Windows default)
# TTS_VOICE=en-US-AriaNeural # edge-tts voice for TARGET_LANG (edge engine only)
# TTS_VOICE_ALT=              # voice for the other language; used by [g] swap
#                             # (empty = auto elegant default for SOURCE_LANG)
# TTS_RATE=+0%
# TTS_VOLUME=+0%
#
# Language swap: press [g] to invert SOURCE ↔ TARGET (STT + translate + TTS voice).

# Piper local TTS (TTS_ENGINE=piper) — pip install piper-tts onnxruntime
# PIPER_VOICE=en_US-lessac-medium   # empty = auto from TARGET_LANG
# PIPER_MODEL_DIR=.cache/models/piper
# PIPER_LENGTH_SCALE=0.9            # lower = faster speech
# PIPER_CHUNK_STREAMING=true        # stream ~60ms ONNX buffers (low latency)
# PIPER_PLAYBACK_BUFFER_MS=60
# PIPER_SEGMENT_MIN_CHARS=70        # split long text / comma clauses for Piper
# PIPER_ORT_THREADS=4               # ONNX CPU threads (0=auto: 4 on Windows)
# PIPER_ONNX_PROVIDER=auto          # auto | cpu | dml (Win GPU) | cuda
# PIPER_QUALITY=fast                # fast=*-low voice (CPU); medium=default
# PIPER_STREAM_FIRST_CHARS=30       # 1st TTS chunk at word boundary; 0=wait for ,
# PIPER_MERGE_TAIL=true             # merge remaining text into one Piper call
# STREAMING_TTS_OVERLAP=true        # start TTS on 1st clause while LLM streams
#
# Sound: press [s] in the terminal to mute/unmute translation playback globally.
# Synonyms: press [o] — offline WordNet by default (no Groq key required).
# SYNONYMS_ENGINE=wordnet        # wordnet | llm | auto (auto falls back to Groq)
# SYNONYMS_PT_TRANSLATE=true     # PT glosses via Google Translate (needs internet)

# ---- Audio devices (index from `python list_devices.py`, or a name substring) ----
# Leave INPUT_DEVICE empty to use the default microphone.
# INPUT_DEVICE=
# OUTPUT_DEVICE=CABLE Input
# MONITOR_PLAYBACK=false       # also play full translation on headphones
# MONITOR_DEVICE=Headset       # REQUIRED for reliable pre-TTS bip (name substring)
# TTS_MONITOR_CUE=true         # bip on headphones ~1s before TTS — NEVER on Cable
# TTS_MONITOR_CUE_LEAD_S=1.0
#
# Mic mute: press [n] in the terminal to mute/unmute the Windows capture device
# (Core Audio / tray-visible) and pause LiveLingo STT. Startup warns if already muted.

# ---- Capture / chunking ----
# VAD_ENABLED=true
# CHUNK_DURATION=4.0
# SILENCE_THRESHOLD=0.015       # raise if noise triggers "Escutando" (laptop: 0.025–0.04)
# VAD_ONSET_BLOCKS=2            # ~60ms energy before speech starts (raise to 6–8 for laptop noise)
# VAD_ONSET_GAP_BLOCKS=2        # allow brief dips mid-onset without reset (first-word clip fix)
# VAD_ONSET_THRESHOLD_SCALE=0.75  # more sensitive while waiting for speech start
# PREROLL_DURATION=0.5          # seconds kept *before* onset (raise if first words cut)
# SILENCE_DURATION=1.2          # base pause before end-of-chunk
# MAX_CHUNK_DURATION=60.0       # force split after N seconds of continuous speech
# VAD_ADAPTIVE_SILENCE=true     # longer speech → longer pause needed to end chunk
# VAD_SILENCE_SCALE_MAX=3.5     # up to ~4s pause after 25s+ of speech
# VAD_SPLIT_OVERLAP=1.5         # overlap when max duration splits mid-monologue
# MIN_SPEECH_DURATION=0.4       # drop chunks shorter than this (clicks / noise)
#
# Laptop / built-in mic (noisy room) — try:
# SILENCE_THRESHOLD=0.028
# VAD_ONSET_BLOCKS=8
# MIN_SPEECH_DURATION=0.6
# # optional neural VAD (better than energy for noise):
# # VAD_MODE=silero
# # SILERO_VAD_THRESHOLD=0.55
#
# ---- Monologue / sound OFF (press [s] to mute) ----
# Sentence-early emit (faster per-phrase text with audio OFF):
# after ~SENTENCE_MIN_SPEECH of speech + SENTENCE_SILENCE pause, emit a chunk
# (STT+translate+UI) and keep listening — does not wait for full monologue.
# Long unfinished answers: raise silence/min speech, or SENTENCE_SPLIT=false.
# SENTENCE_SPLIT=true
# SENTENCE_SPLIT_SOUND_OFF_ONLY=true   # false = also split while sound ON
# SENTENCE_SILENCE=0.95                # pause (s); 0.55 cut mid-breath too often
# SENTENCE_MIN_SPEECH=2.5              # min speech (s) before a split
# SENTENCE_SPLIT_OVERLAP=0.25
# SENTENCE_SILENCE_SCALE_MAX=2.5       # grow required pause on long monologues
# Legacy long-pause split (used when SENTENCE_SPLIT=false):
# PARAGRAPH_SPLIT=true
# PARAGRAPH_SPLIT_SOUND_OFF_ONLY=true
# PARAGRAPH_SILENCE=1.2
# PARAGRAPH_MIN_SPEECH=5.0
# PARAGRAPH_SPLIT_OVERLAP=0.3
# SOUND_OFF_PARALLEL=true         # parallel STT+translate workers when muted
# SOUND_OFF_WORKERS=2
# TTS_SKIP_WHEN_MUTED=true        # skip TTS when muted (saves CPU; no replay audio)
# SOUND_OFF_SILENCE_DURATION=1.8  # base end pause when muted (adaptive scales up)

# ---- Low-latency profile (aggressive speed; trades some quality) ----
# Uncomment the block below for faster text + audio response:
# STT_ENGINE=groq
# GROQ_STT_MODEL=whisper-large-v3-turbo
# TRANSLATION_ENGINE=llm
# GROQ_MODEL=llama-3.1-8b-instant
# LOW_LATENCY=true
# SILENCE_DURATION=0.4
# MAX_CHUNK_DURATION=6.0
# TTS_RATE=+20%
# WHISPER_MODEL=tiny
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_BEAM_SIZE=1
# WHISPER_VAD_FILTER=false
# WHISPER_CPU_THREADS=0

# ---- Phase 3 — streaming capture/playback (on by default) ----
# STREAMING_LLM=true          # stream Groq translation tokens to terminal
# STREAMING_TTS=true          # TTS sentence-by-sentence (faster first audio)
# VAD_MODE=energy             # energy | silero (silero needs: pip install onnxruntime)
# SILERO_VAD_THRESHOLD=0.45
# ROLLING_CHUNKS=false        # emit partial chunks while still speaking
# ROLLING_CHUNK_DURATION=2.5
# PLAYBACK_INTERRUPT=true     # cut off stale audio when a new chunk arrives
# PLAYBACK_BLOCK_MS=80
#
# Acoustic feedback guard (speaker + same notebook mic):
# MUTE_CAPTURE_DURING_PLAYBACK=true   # pause STT capture while TTS plays
# MUTE_CAPTURE_HANGOVER_MS=350        # wait after TTS before reopening mic
# Prefer headphones + VB-Cable for real calls; this is a software safety net.

# ---- UI ----
# tui = Textual full-screen (scrollable log + fixed listen bar at bottom)
# classic = legacy colorama prints + readline
# UI_MODE=tui
# Open TUI already compact (menu strip hidden; command line stays). Same as F4/[u] at launch.
# TUI_MINIMAL=false

# ---- Live Captions (Windows 11 only; strip above log tabs in TUI) ----
# Scrapes Windows LiveCaptions via UI Automation → translate → #captions-panel.
# Independent of mic→Whisper→TTS. Needs: pip install uiautomation
# Set speech language in LiveCaptions settings (⚙️), not only SOURCE_LANG.
# LIVE_CAPTIONS_ENABLED=true
# LIVE_CAPTIONS_HIDE_WINDOW=true
# LIVE_CAPTIONS_KILL_ON_EXIT=false
# LIVE_CAPTIONS_LOG=true
# LIVE_CAPTIONS_POLL_MS=25
# LIVE_CAPTIONS_MAX_IDLE=50
# LIVE_CAPTIONS_MAX_SYNC=3
# Direction (inbound captions vs outbound voice):
#   Voice BR→EN (you speak PT) → captions default EN→BR (you read PT).
# LIVE_CAPTIONS_INVERT_LANGS=true
# Or force pair (overrides invert when both set):
# LIVE_CAPTIONS_SOURCE_LANG=en
# LIVE_CAPTIONS_TARGET_LANG=pt
# Runtime: lc | lc on|off | lc show|hide | lc status

# ---- Webcam lip-sync → virtual camera (Teams/Meet) ----
# Optional module: capture webcam, lip-sync to TTS (Cable Out), emit pyvirtualcam.
# pip install opencv-python mediapipe pyvirtualcam
# ONNX GPU (optional): pip install onnxruntime-gpu
# Drivers: OBS Virtual Cam (Windows) or v4l2loopback (Linux). See docs/webcam-lipsync.md
# WEBCAM_ENABLED=false
# WEBCAM_START_ENABLED=false   # true = stream immediately; false = wait for [cam on]
# WEBCAM_DEVICE_INDEX=0
# WEBCAM_WIDTH=0               # 0 = native camera resolution
# WEBCAM_HEIGHT=0
# WEBCAM_FPS=30
# WEBCAM_QUEUE_SIZE=2          # drop-old queues (latency bound)
# WEBCAM_LIP_ENGINE=amplitude  # amplitude | passthrough | onnx
# WEBCAM_ONNX_MODEL=           # path to .onnx when engine=onnx
# WEBCAM_ONNX_INPUT_SIZE=96
# WEBCAM_ONNX_FP16=true
# WEBCAM_ROI_PAD=0.35
# WEBCAM_FEATHER_PX=9
# WEBCAM_SYNC_MARKER=true     # bar + pulse near mouth while TTS plays
# WEBCAM_FORCE_CLOSED_IDLE=true  # closed mouth until TTS → Teams
# WEBCAM_CLOSED_AUTO=true        # VAD auto closed photo (F10 switches to manual)
# WEBCAM_CLOSED_MOUTH_IMAGE=.cache/webcam/closed_mouth.png
# WEBCAM_CLOSED_MOUTH_LANDMARKS=.cache/webcam/closed_mouth.json
# WEBCAM_TEMPLATE_REGION_SCALE=1.15  # full-face freeze pad (1.0 tight … 1.4 larger)
# WEBCAM_TEMPLATE_FEATHER_PX=24      # soft edge of face plate (F10)
# WEBCAM_TEMPLATE_FLIP_H=false      # true only if mouth photo is left-right swapped
# WEBCAM_SPEECH_HANGOVER_S=1.5      # keep closed photo after speech ends (mic lag)
# # Capture: cam snap closed (mouth closed, face the camera)
# WEBCAM_AUDIO_PLAY_DELAY_S=0.08  # morph start lag vs Cable Out
# WEBCAM_VCAM_BACKEND=         # empty=auto; obs | v4l2loopback | unitycapture
# WEBCAM_VCAM_DEVICE=
# Runtime: cam | cam on|off | cam status
