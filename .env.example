# Copy this file to ".env" and edit the values you want to override.
# Anything left commented out falls back to the default in config.py.

# ---- Languages ----
# SOURCE_LANG=fr
# TARGET_LANG=en

# ---- Groq API (free key, no credit card: https://console.groq.com/keys) ----
# One key powers BOTH cloud transcription (Whisper) and LLM translation.
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ---- Translation engine ----
# auto (LLM if GROQ_API_KEY set, else Google) | llm | google
# TRANSLATION_ENGINE=auto
# GROQ_MODEL=llama-3.3-70b-versatile

# ---- Speech-to-text engine ----
# STT_ENGINE: auto (Groq if a key is set, else local) | groq | local
# Groq runs whisper-large-v3 — much more accurate than the small local model,
# free, fast, and offloads your CPU. Needs GROQ_API_KEY (same key as below) + net.
# STT_ENGINE=auto
# GROQ_STT_MODEL=whisper-large-v3      # or whisper-large-v3-turbo (faster)
# GROQ_STT_TIMEOUT=20.0
# Bias recognition toward your vocabulary / names / accents (both engines):
# STT_INITIAL_PROMPT=Réunion sur LiveLingo, VB-Cable, Whisper, Groq, Teams.
# STT_HALLUCINATION_FILTER=true   # drop "Legenda por …" etc. on silent tails

# ---- Local Whisper (used when STT_ENGINE=local, or as a fallback) ----
# WHISPER_MODEL=small          # tiny | base | small | medium | large-v3 | large-v3-turbo
# WHISPER_DEVICE=cpu           # cpu | cuda
# WHISPER_COMPUTE_TYPE=int8    # int8 (cpu) | float16 (gpu)
# WHISPER_BEAM_SIZE=5
# WHISPER_VAD_FILTER=true

# ---- Text-to-speech ----
# TTS_ENGINE=edge            # edge | piper | hybrid (edge 1st chunk + piper tail)
# TTS_HYBRID=true            # with piper: edge for first live chunk (Windows default)
# TTS_VOICE=en-US-AriaNeural # edge-tts voice (edge engine only)
# TTS_RATE=+0%
# TTS_VOLUME=+0%

# Piper local TTS (TTS_ENGINE=piper) — pip install piper-tts onnxruntime
# PIPER_VOICE=en_US-lessac-medium   # empty = auto from TARGET_LANG
# PIPER_MODEL_DIR=.cache/models/piper
# PIPER_LENGTH_SCALE=0.9            # lower = faster speech
# PIPER_CHUNK_STREAMING=true        # stream ~60ms ONNX buffers (low latency)
# PIPER_PLAYBACK_BUFFER_MS=60
# PIPER_SEGMENT_MIN_CHARS=70        # split long text / comma clauses for Piper
# PIPER_ORT_THREADS=4               # ONNX CPU threads (0=auto: 4 on Windows)
# PIPER_ONNX_PROVIDER=auto          # auto | cpu | dml (Win GPU) | cuda
# PIPER_QUALITY=fast                # fast=*-low voice (CPU); medium=default
# PIPER_STREAM_FIRST_CHARS=30       # 1st TTS chunk at word boundary; 0=wait for ,
# PIPER_MERGE_TAIL=true             # merge remaining text into one Piper call
# STREAMING_TTS_OVERLAP=true        # start TTS on 1st clause while LLM streams
#
# Sound: press [s] in the terminal to mute/unmute translation playback globally.
# Synonyms: press [o] — offline WordNet by default (no Groq key required).
# SYNONYMS_ENGINE=wordnet        # wordnet | llm | auto (auto falls back to Groq)
# SYNONYMS_PT_TRANSLATE=true     # PT glosses via Google Translate (needs internet)

# ---- Audio devices (index from `python list_devices.py`, or a name substring) ----
# Leave INPUT_DEVICE empty to use the default microphone.
# INPUT_DEVICE=
# OUTPUT_DEVICE=CABLE Input
# MONITOR_PLAYBACK=false       # also play translation on your own speakers
# MONITOR_DEVICE=              # which device to monitor on (index/name); empty=default output

# ---- Capture / chunking ----
# VAD_ENABLED=true
# CHUNK_DURATION=4.0
# SILENCE_THRESHOLD=0.015
# SILENCE_DURATION=1.2          # base pause before end-of-chunk
# MAX_CHUNK_DURATION=60.0       # force split after N seconds of continuous speech
# VAD_ADAPTIVE_SILENCE=true     # longer speech → longer pause needed to end chunk
# VAD_SILENCE_SCALE_MAX=3.5     # up to ~4s pause after 25s+ of speech
# VAD_SPLIT_OVERLAP=1.5         # overlap when max duration splits mid-monologue
# MIN_SPEECH_DURATION=0.4
#
# ---- Monologue / sound OFF (press [s] to mute) ----
# PARAGRAPH_SPLIT=true            # split on short pauses during long speech
# PARAGRAPH_SPLIT_SOUND_OFF_ONLY=true
# PARAGRAPH_SILENCE=1.0           # pause (s) between paragraphs → early chunk
# PARAGRAPH_MIN_SPEECH=5.0        # min speech (s) before paragraph split
# SOUND_OFF_PARALLEL=true         # parallel STT+translate workers when muted
# SOUND_OFF_WORKERS=2
# TTS_SKIP_WHEN_MUTED=true        # skip TTS when muted (saves CPU; no replay audio)
# SOUND_OFF_SILENCE_DURATION=2.0  # shorter end pause when muted (default 2s)

# ---- Low-latency profile (aggressive speed; trades some quality) ----
# Uncomment the block below for faster text + audio response:
# STT_ENGINE=groq
# GROQ_STT_MODEL=whisper-large-v3-turbo
# TRANSLATION_ENGINE=llm
# GROQ_MODEL=llama-3.1-8b-instant
# LOW_LATENCY=true
# SILENCE_DURATION=0.4
# MAX_CHUNK_DURATION=6.0
# TTS_RATE=+20%
# WHISPER_MODEL=tiny
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_BEAM_SIZE=1
# WHISPER_VAD_FILTER=false
# WHISPER_CPU_THREADS=0

# ---- Phase 3 — streaming capture/playback (on by default) ----
# STREAMING_LLM=true          # stream Groq translation tokens to terminal
# STREAMING_TTS=true          # TTS sentence-by-sentence (faster first audio)
# VAD_MODE=energy             # energy | silero (silero needs: pip install onnxruntime)
# SILERO_VAD_THRESHOLD=0.45
# ROLLING_CHUNKS=false        # emit partial chunks while still speaking
# ROLLING_CHUNK_DURATION=2.5
# PLAYBACK_INTERRUPT=true     # cut off stale audio when a new chunk arrives
# PLAYBACK_BLOCK_MS=80
