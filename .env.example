# Copy this file to ".env" and edit the values you want to override.
# Anything left commented out falls back to the default in config.py.

# ---- Languages ----
# SOURCE_LANG=fr
# TARGET_LANG=en

# ---- Whisper / speech-to-text ----
# WHISPER_MODEL=small          # tiny | base | small | medium | large-v3
# WHISPER_DEVICE=cpu           # cpu | cuda
# WHISPER_COMPUTE_TYPE=int8    # int8 (cpu) | float16 (gpu)
# WHISPER_BEAM_SIZE=5
# WHISPER_VAD_FILTER=true

# ---- Text-to-speech (edge-tts) ----
# TTS_VOICE=en-US-AriaNeural
# TTS_RATE=+0%
# TTS_VOLUME=+0%

# ---- Audio devices (index from `python list_devices.py`, or a name substring) ----
# Leave INPUT_DEVICE empty to use the default microphone.
# INPUT_DEVICE=
# OUTPUT_DEVICE=CABLE Input
# MONITOR_PLAYBACK=false       # also play translation on your own speakers
# MONITOR_DEVICE=              # which device to monitor on (index/name); empty=default output

# ---- Capture / chunking ----
# VAD_ENABLED=true
# CHUNK_DURATION=4.0
# MAX_CHUNK_DURATION=10.0
# SILENCE_THRESHOLD=0.015
# SILENCE_DURATION=0.7
# MIN_SPEECH_DURATION=0.4
